{
  "manifest_version": 3,
  "name": "GDrive Universal Downloader",
  "version": "3.6.1",
  "browser_specific_settings": {
    "gecko": {
      "id": "gdrive-universal-downloader@extension",
      "strict_min_version": "128.0"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "description": "Download images, PDFs, and videos from any webpage, plus Google Drive and YouTube.",
  "permissions": ["activeTab", "scripting", "downloads", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-hooks.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}
